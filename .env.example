DISCORD_TOKEN=your-bot-token-here
DISCORD_CHANNEL_ID=1522523417838878761

# Channel where WIN/LOSS notifications get posted when a trade closes.
# Separate from the main alert channel so closed-trade results don't get
# lost among new signals.
CLOSED_TRADES_CHANNEL_ID=1522186333718843453

# --- Scanning & Session ---

# Trading session window (Europe/Berlin time, DST-aware). The bot scans
# continuously during this window instead of just once a day.
SESSION_START_HOUR=8
SESSION_END_HOUR=23
SCAN_WEEKENDS=false

# How often to scan during the session, in minutes. Every scan both looks
# for new trades AND checks all open trades for near-close proximity.
SCAN_INTERVAL_MINUTES=5

# A signal must appear the same way on this many CONSECUTIVE scans before
# it's confirmed and alerted -- filters flicker from today's still-forming
# daily candle. Higher = fewer false alarms, but slower to alert.
SIGNAL_CONFIRMATION_SCANS=2

# DEBUG shows per-horizon scanning detail and full confidence breakdowns
# for every scenario checked, not just the ones that alert.
LOG_LEVEL=INFO

# --- Trade Filters & Risk ---

# Hard filter, enforced exactly as set: a scenario is dropped entirely
# (not shown, not scored) unless its target sits at least this much
# away from TODAY'S CURRENT PRICE -- e.g. a €100 stock needs its next
# support/resistance at/beyond €101.50 (bullish) or €98.50 (bearish).
# Applies equally to bullish and bearish scenarios. No exceptions for a
# close miss -- there is no "shown anyway, just marked" fallback for
# this one.
MIN_REWARD_PCT=1.5

# Hard filter, enforced exactly as set: dropped entirely if the stop
# sits closer than this to entry -- too exposed to ordinary daily noise
# to be a clean setup. No exceptions for a close miss.
MIN_STOP_DISTANCE_PCT=1.0

# Hard filter, enforced exactly as set: dropped entirely if the stop
# sits further than this from entry. Disciplined swing/position sizing
# caps a cut-loss around 5-7% of entry -- keep this in that range. No
# exceptions for a close miss.
MAX_STOP_LOSS_PCT=7.0

# Hard filter, enforced exactly as set: dropped entirely unless the
# reward:risk to target 1 is at least this ratio. No exceptions for a
# close miss.
MIN_RISK_REWARD_RATIO=1.5

# How close (as a %) an independent strategy's own predicted level has
# to land to a scenario's actual target/stop price to count as
# confirming it (see MIN_TARGET_CONFLUENCE_COUNT below). Looser than the
# tight clustering tolerance levels.py uses internally to decide what
# counts as "the same level" when building it in the first place.
CONFLUENCE_DEVIATION_PCT=5.0

# A scenario is flagged unless at least this many DISTINCT strategies
# (EMA, VWAP, Fibonacci, rolling structure, zigzag pivots, Bollinger
# Bands, Donchian Channel, floor pivots, trendlines, Fair Value Gaps --
# 10 total) land within CONFLUENCE_DEVIATION_PCT of the target price. 1
# disables this requirement. Can also be overridden for a single run
# with `!check <horizon> <min_strategies>` without touching this setting.
MIN_TARGET_CONFLUENCE_COUNT=1

# Quality-over-quantity: only Level 3 (Medium) and above count as a
# clean, auto-postable setup. Lower levels are still computed and shown
# (e.g. via !check, marked as not meeting this requirement) rather than
# hidden -- they just won't auto-alert.
MIN_ALERT_CONFIDENCE_LEVEL=3

# Two signals on the same ticker/direction with entry, SL, and TP all
# within this % of each other get merged into one alert instead of
# duplicated.
DEDUP_TOLERANCE_PCT=2.0

# How close (in %) the current price must get to a trade's stop-loss or
# take-profit before a near-close warning posts to CLOSED_TRADES_CHANNEL_ID.
# Fires once per approach; resets if price moves back away.
NEAR_CLOSE_THRESHOLD_PCT=2.0

# --- Data & Display ---

# How much daily history to pull for live scanning. More history gives
# indicators (especially EMA200, 6-month lookbacks) more stable context.
DEFAULT_HISTORY_PERIOD=10y

# Fallback currency symbol, used only when a ticker's real trading
# currency can't be detected.
CURRENCY_SYMBOL=€

# Market regime benchmark ticker (used to gauge overall market trend)
MARKET_REGIME_TICKER=SPY

# --- Account Defaults ---

# Editable at runtime via !account, stored in account.json after first
# run -- currently informational only. There is no euro-based position
# sizing: the bot's focus is entirely on finding a genuine, multi-
# strategy-confirmed support/resistance setup (see levels.py), not on
# how much money to put behind it.
ACCOUNT_BALANCE=10000
RISK_PER_TRADE_PCT=1.0
MAX_OPEN_POSITIONS=5

# --- Admin UI ---

# Protects the admin web UI (docker-compose.yml's `admin` service,
# admin_ui.py -- clear open trades, edit .env) with HTTP Basic Auth.
# CHANGE THESE -- the defaults are not safe to leave in place.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
# Port the admin UI listens on inside its container. docker-compose.yml
# maps this to the same port on the host (1234:1234) -- change both
# together if you need a different port.
ADMIN_PORT=1234
