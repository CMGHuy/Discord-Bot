# --- Discord Connection ---

DISCORD_TOKEN=your-bot-token-here

# Main channel where new trade alerts are posted.
DISCORD_CHANNEL_TRADES_ID=your-alerts-channel-id

# Channel where WIN/LOSS notifications get posted when a trade closes.
# Separate from the main alert channel so closed-trade results don't get
# lost among new signals.
DISCORD_CHANNEL_TRADES_HISTORY_ID=your-closed-trades-channel-id

# Channel where the end-of-session retrospective is posted on weekdays
# (Mon–Fri at SESSION_END_HOUR:15 Berlin time). Leave blank to fall back
# to DISCORD_CHANNEL_TRADES_HISTORY_ID.
DISCORD_CHANNEL_RETROSPECTIVE_ID=your-retrospective-channel-id

# --- Scanning & Session ---

# Trading session window (Europe/Berlin time, DST-aware). The bot scans
# continuously during this window instead of just once a day.
SESSION_START_HOUR=8
SESSION_END_HOUR=23

# How often to scan during the session, in minutes. Every scan both looks
# for new trades AND checks all open trades for near-close proximity.
SCAN_INTERVAL_MINUTES=5

# A signal must appear the same way on this many CONSECUTIVE scans before
# it's confirmed and alerted -- filters flicker from today's still-forming
# daily candle. Higher = fewer false alarms, but slower to alert.
SIGNAL_CONFIRMATION_SCANS=2

# DEBUG shows per-horizon scanning detail and full confidence breakdowns
# for every scenario checked, not just the ones that alert.
LOG_LEVEL=INFO

# --- Trade Filters & Risk ---

# Hard filter, enforced exactly as set: a scenario is dropped entirely
# (not shown, not scored) unless its target sits at least this much
# away from TODAY'S CURRENT PRICE. No exceptions for a close miss.
MIN_REWARD_PCT=3.0

# Hard filter: dropped entirely if the stop sits closer than this to
# entry -- too exposed to ordinary daily noise. No exceptions.
MIN_STOP_DISTANCE_PCT=2.0

# Hard filter: dropped entirely if the stop sits further than this from
# entry. Keep this in the 5–7% range for disciplined position sizing.
MAX_STOP_LOSS_PCT=7.0

# Hard filter: dropped entirely unless the reward:risk to target 1
# clears this ratio. No exceptions for a close miss.
MIN_RISK_REWARD_RATIO=1.5

# How close (as a %) an independent strategy's own predicted level has
# to land to a scenario's actual target/stop price to count as
# confirming it (see MIN_TARGET_CONFLUENCE_COUNT below).
CONFLUENCE_DEVIATION_PCT=5.0

# A scenario is flagged unless at least this many DISTINCT strategies
# land within CONFLUENCE_DEVIATION_PCT of the target price.
# 1 disables this requirement.
MIN_TARGET_CONFLUENCE_COUNT=2

# Only Level 4 (High) and above auto-alert. Lower levels are still
# computed and shown via !check but won't post automatically.
MIN_ALERT_CONFIDENCE_LEVEL=4

# Two signals on the same ticker/direction with entry, SL, and TP all
# within this % of each other get merged into one alert.
DEDUP_TOLERANCE_PCT=2.0

# Post a warning when an open trade's price gets within NEAR_CLOSE_THRESHOLD_PCT
# of its SL/TP. Set to false to temporarily silence these without losing the
# threshold below -- SL/TP hits themselves are unaffected either way.
NEAR_CLOSE_ALERTS_ENABLED=false

# How close (in %) the current price must get to a trade's stop-loss or
# take-profit before a near-close warning posts to
# DISCORD_CHANNEL_TRADES_HISTORY_ID. Fires once per approach.
NEAR_CLOSE_THRESHOLD_PCT=2.0

# If a trade reaches NEAR_TP_TIMEOUT_THRESHOLD_PCT of the way to its target
# (as a % of the entry -> target 1 distance) and then sits there without
# actually touching the target for NEAR_TP_TIMEOUT_MINUTES, it's closed early
# at the live price to lock in the profit already made instead of risking it
# waiting for the exact target price. Dropping back below the threshold
# resets the clock. Set NEAR_TP_TIMEOUT_ENABLED=false to disable entirely.
#
# A faster exit than the full timeout: once price is in the near-TP zone,
# NEAR_TP_STALL_CHECK_MINUTES/_MAX_FLUCTUATION_PCT close the trade early if
# price hasn't moved more than the fluctuation % within that shorter window
# (must be less than NEAR_TP_TIMEOUT_MINUTES).
NEAR_TP_TIMEOUT_ENABLED=true
NEAR_TP_TIMEOUT_THRESHOLD_PCT=80.0
NEAR_TP_TIMEOUT_MINUTES=10
NEAR_TP_STALL_CHECK_MINUTES=5
NEAR_TP_STALL_MAX_FLUCTUATION_PCT=0.5

# How many past trading days the daily retrospective remembers, so it can
# notice repeating problems (e.g. "3rd day in a row") instead of treating
# every day in isolation with no memory of what was said yesterday.
RETROSPECTIVE_HISTORY_DAYS=60

# --- Multi-Timeframe Confluence ---

# Check each ticker's higher-timeframe EMA bias before accepting a signal.
# Counter-trend signals are penalised by HTF_COUNTER_TREND_PENALTY points.
HTF_CONFLUENCE_ENABLED=true

# Raw confidence score points subtracted when a signal goes against its
# ticker's own higher-timeframe EMA trend. 15 drops a borderline Lv3
# signal to Lv2 and below the default MIN_ALERT_CONFIDENCE_LEVEL gate.
HTF_COUNTER_TREND_PENALTY=15

# --- Data & Display ---

# How much daily history to pull for live scanning.
DEFAULT_HISTORY_PERIOD=10y

# Fallback currency symbol when a ticker's real currency can't be detected.
CURRENCY_SYMBOL=€

# Market regime benchmark ticker (used to gauge overall market trend).
MARKET_REGIME_TICKER=SPY

# --- Account Defaults ---

# Editable at runtime via !account, stored in account.json after first run.
ACCOUNT_BALANCE=1000000
RISK_PER_TRADE_PCT=1.0
MAX_OPEN_POSITIONS=30
MAX_POSITION_SIZE_PCT=5.0

# How each trade's position size is calculated:
#   risk_pct    -- fixed-fractional (original model): size so a full stop-out
#                  costs exactly RISK_PER_TRADE_PCT% of the account.
#   account_pct -- fixed allocation: the position itself is always exactly
#                  POSITION_SIZE_PCT_OF_ACCOUNT% of the account balance,
#                  regardless of stop distance (e.g. 0.1% of a €1,000,000
#                  account opens a €1,000 position every time).
# Both are editable at runtime via !account sizing / !account positionpct.
POSITION_SIZING_MODE=risk_pct
POSITION_SIZE_PCT_OF_ACCOUNT=0.1

# --- Secondary Alerts (optional) ---

# Send email alerts via SMTP in addition to Discord.
ALERT_EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

# Send push notifications via ntfy.sh (free, no account needed).
ALERT_PUSH_ENABLED=false
NTFY_TOPIC=

# --- Admin UI ---

# Protects the admin web UI with HTTP Basic Auth. CHANGE THESE.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
# Port the admin UI listens on (docker-compose.yml maps this to the host).
ADMIN_PORT=1234
DASHBOARD_REFRESH_SECONDS=10
LOGS_REFRESH_SECONDS=10
